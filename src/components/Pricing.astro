---
const features = [
  {
    title: "До 5 устройств одновременно",
    desc: "Смотрите на телевизоре, телефоне и планшете — всё сразу, без конфликтов.",
    icon: "M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z",
  },
  {
    title: "Скачивание сериалов и фильмов",
    desc: "Загружайте любую серию, сезон или весь сериал целиком и смотрите офлайн — в дороге, в самолёте, где угодно.",
    icon: "M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3",
  },
];
---

<section id="pricing" class="pricing">
  <div class="container pricing__inner">
    <div class="pricing__card glass glow-card reveal">
      <div class="pricing__glow" aria-hidden="true"></div>

      <span class="pricing__badge">PRO</span>

      <h2 class="pricing__title">Поддержи проект<br /><span class="gradient-text">и стань PRO</span></h2>
      <p class="pricing__lede">
        Сервис существует на энтузиазме создателей и пользователей.
        Небольшое пожертвование помогает всем нам — и вы получаете PRO-аккаунт.
      </p>

      <ul class="pricing__features">
        {
          features.map((f) => (
            <li class="pricing__feature">
              <span class="pricing__feature-icon">
                <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon} /></svg>
              </span>
              <span>
                <strong>{f.title}</strong>
                <em>{f.desc}</em>
              </span>
            </li>
          ))
        }
      </ul>

      <a href="https://sakhtv.club/" class="btn btn-primary pricing__cta" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
        Поддержать проект
      </a>
      <p class="pricing__fine">PRO-аккаунт активируется автоматически после поддержки.</p>
    </div>
  </div>
</section>

<style>
  .pricing__inner {
    display: flex;
    justify-content: center;
  }

  .pricing__card {
    position: relative;
    width: 100%;
    max-width: 680px;
    padding: clamp(2rem, 4vw, 3.25rem);
    border-radius: var(--r-xl);
    text-align: center;
    overflow: hidden;
  }

  .pricing__glow {
    position: absolute;
    top: -60%;
    left: 50%;
    transform: translateX(-50%);
    width: 120%;
    height: 120%;
    background: radial-gradient(circle, rgba(255, 77, 157, 0.18), transparent 60%);
    pointer-events: none;
  }

  .pricing__badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    padding: 0.35rem 0.9rem;
    border-radius: var(--r-pill);
    background: var(--grad-accent);
    color: #fff;
    box-shadow: 0 6px 22px -6px var(--glow-fuchsia);
    margin-bottom: 1.5rem;
  }

  .pricing__title {
    font-size: clamp(1.9rem, 1.2rem + 2.6vw, 2.8rem);
    margin-bottom: 1rem;
  }
  .pricing__lede {
    color: var(--text-mute);
    max-width: 46ch;
    margin-inline: auto;
    margin-bottom: 2.25rem;
    line-height: 1.6;
  }

  .pricing__features {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.25rem;
    text-align: left;
  }
  .pricing__feature {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.1rem 1.2rem;
    border-radius: var(--r-md);
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid var(--glass-border);
  }
  .pricing__feature-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--r-sm);
    display: grid;
    place-items: center;
    color: var(--neon-violet);
    background: rgba(124, 92, 255, 0.1);
  }
  .pricing__feature strong { display: block; font-size: 1.02rem; margin-bottom: 0.15rem; }
  .pricing__feature em { font-style: normal; color: var(--text-mute); font-size: 0.9rem; line-height: 1.5; }

  .pricing__cta { width: 100%; max-width: 320px; margin-inline: auto; }
  .pricing__fine {
    margin-top: 1rem;
    color: var(--text-faint);
    font-size: 0.82rem;
  }
</style>
